# ─── Core ────────────────────────────────────────────────────────────────────
# Supabase project URL (Settings → API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
# Supabase anon (public) key — RLS-scoped, safe for the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase service-role key — bypasses RLS. Edge functions + server-only code. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Public URL of this deployment, e.g. https://engine.socivo.co.uk
APP_URL=
# 32-byte hex string (64 hex chars). Encrypts OAuth refresh tokens and provider API keys at rest.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
# Domain serving tracking pixel / click redirect / unsubscribe pages, e.g. go.socivo.co.uk (CNAME to Vercel)
TRACKING_DOMAIN=

# ─── OAuth apps (you supply) ─────────────────────────────────────────────────
# Google Cloud Console → OAuth client (Web). Redirect URI: {APP_URL}/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Azure App Registration. Redirect URI: {APP_URL}/api/oauth/microsoft/callback
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# 'common' allows any org + personal Microsoft accounts
MS_TENANT=common

# ─── AI chain (in priority order; any subset works — chain skips absent keys) ─
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
# Optional. Used for research briefs only (ai_brief capability) when present.
ANTHROPIC_API_KEY=

# ─── Verification chain ──────────────────────────────────────────────────────
REOON_API_KEY=
MILLIONVERIFIER_API_KEY=
ZEROBOUNCE_API_KEY=
HUNTER_API_KEY=

# ─── Research chain ──────────────────────────────────────────────────────────
SERPER_API_KEY=
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
# Optional — Jina Reader works keyless at low volume; key raises limits
JINA_API_KEY=
# Optional. LinkedIn enrichment toggle stays off without it.
APIFY_TOKEN=

# ─── Notifications (optional) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
N8N_WEBHOOK_URL=
